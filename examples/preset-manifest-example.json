{
  "name": "multi-provider-example",
  "version": "1.0.0",
  "description": "Multi-provider configuration example - supports switching between OpenAI and DeepSeek",
  "author": "CCR Team",
  "keywords": ["openai", "deepseek", "multi-provider"],
  "ccrVersion": "2.0.0",
  "Providers": [
    {
      "name": "openai",
      "api_base_url": "https://api.openai.com/v1",
      "models": ["gpt-4o", "gpt-4o-mini", "gpt-3.5-turbo"]
    },
    {
      "name": "deepseek",
      "api_base_url": "https://api.deepseek.com",
      "models": ["deepseek-v3", "deepseek-chat"]
    }
  ],
  "schema": [
    {
      "id": "primaryProvider",
      "type": "select",
      "label": "Primary Provider",
      "prompt": "Select your primary LLM provider",
      "options": {
        "type": "providers"
      },
      "required": true,
      "defaultValue": "openai"
    },
    {
      "id": "apiKey",
      "type": "password",
      "label": "API Key",
      "prompt": "Please enter your API Key (will be read from environment variables or secure storage)",
      "placeholder": "sk-...",
      "required": true,
      "when": {
        "field": "primaryProvider",
        "operator": "exists"
      }
    },
    {
      "id": "customBaseUrl",
      "type": "input",
      "label": "Custom Base URL",
      "prompt": "If using a proxy or custom endpoint, enter the Base URL (leave blank to use default)",
      "placeholder": "https://api.openai.com/v1",
      "required": false,
      "when": {
        "field": "primaryProvider",
        "operator": "exists"
      }
    },
    {
      "id": "defaultModel",
      "type": "select",
      "label": "Default Model",
      "prompt": "Select the default model to use",
      "options": {
        "type": "models",
        "providerField": "{{primaryProvider}}"
      },
      "required": true,
      "defaultValue": "gpt-4o",
      "when": {
        "field": "primaryProvider",
        "operator": "eq",
        "value": "openai"
      }
    },
    {
      "id": "backgroundModel",
      "type": "select",
      "label": "Background Task Model",
      "prompt": "Lightweight model for background tasks",
      "options": {
        "type": "models",
        "providerField": "{{primaryProvider}}"
      },
      "required": false,
      "when": {
        "field": "primaryProvider",
        "operator": "exists"
      }
    },
    {
      "id": "enableProxy",
      "type": "confirm",
      "label": "Enable Proxy",
      "prompt": "Do you want to access the API via proxy?",
      "defaultValue": false
    },
    {
      "id": "proxyUrl",
      "type": "input",
      "label": "Proxy Address",
      "prompt": "Enter proxy server address",
      "placeholder": "http://127.0.0.1:7890",
      "required": true,
      "when": {
        "field": "enableProxy",
        "operator": "eq",
        "value": true
      }
    },
    {
      "id": "maxTokens",
      "type": "number",
      "label": "Max Tokens",
      "prompt": "Set the maximum token count for a single request",
      "min": 100,
      "max": 128000,
      "defaultValue": 4096,
      "required": false
    },
    {
      "id": "timeout",
      "type": "number",
      "label": "Request Timeout (seconds)",
      "prompt": "API request timeout",
      "min": 10,
      "max": 300,
      "defaultValue": 60,
      "required": false
    },
    {
      "id": "enableFeatures",
      "type": "multiselect",
      "label": "Enable Features",
      "prompt": "Select features to enable",
      "options": {
        "type": "static",
        "options": [
          {
            "label": "Streaming Output",
            "value": "stream",
            "description": "Real-time display of AI responses"
          },
          {
            "label": "Tool Calls",
            "value": "tools",
            "description": "Enable Function Calling"
          },
          {
            "label": "Long Context",
            "value": "longContext",
            "description": "Support for long text processing"
          },
          {
            "label": "Chain of Thought",
            "value": "think",
            "description": "Use in thinking mode"
          }
        ]
      },
      "defaultValue": ["stream", "tools"],
      "required": false
    },
    {
      "id": "advancedMode",
      "type": "confirm",
      "label": "Advanced Mode",
      "prompt": "Enable advanced configuration options?",
      "defaultValue": false
    },
    {
      "id": "temperature",
      "type": "number",
      "label": "Temperature",
      "prompt": "Control generation randomness (0-2, higher values are more random)",
      "min": 0,
      "max": 2,
      "defaultValue": 0.7,
      "required": false,
      "when": {
        "field": "advancedMode",
        "operator": "eq",
        "value": true
      }
    },
    {
      "id": "logLevel",
      "type": "select",
      "label": "Log Level",
      "prompt": "Set a detailed log level",
      "options": {
        "type": "static",
        "options": [
          {
            "label": "Error",
            "value": "error"
          },
          {
            "label": "Warning",
            "value": "warn"
          },
          {
            "label": "Info",
            "value": "info"
          },
          {
            "label": "Debug",
            "value": "debug"
          }
        ]
      },
      "defaultValue": "info",
      "required": false,
      "when": {
        "field": "advancedMode",
        "operator": "eq",
        "value": true
      }
    }
  ],
  "template": {
    "Providers": [
      {
        "name": "{{primaryProvider}}",
        "api_base_url": "{{customBaseUrl}}",
        "api_key": "{{apiKey}}",
        "models": ["{{defaultModel}}", "{{backgroundModel}}"]
      }
    ],
    "Router": {
      "default": "{{primaryProvider}}/{{defaultModel}}",
      "background": "{{backgroundModel}}",
      "think": "{{primaryProvider}}/{{defaultModel}}"
    },
    "PROXY_URL": "{{proxyUrl}}",
    "API_TIMEOUT_MS": 60000,
    "LOG_LEVEL": "info"
  },
  "configMappings": [
    {
      "target": "Providers[0].api_base_url",
      "value": "{{customBaseUrl}}",
      "when": {
        "field": "customBaseUrl",
        "operator": "exists"
      }
    },
    {
      "target": "PROXY_URL",
      "value": "{{proxyUrl}}",
      "when": {
        "field": "enableProxy",
        "operator": "eq",
        "value": true
      }
    },
    {
      "target": "API_TIMEOUT_MS",
      "value": 60000
    },
    {
      "target": "LOG_LEVEL",
      "value": "{{logLevel}}",
      "when": {
        "field": "advancedMode",
        "operator": "eq",
        "value": true
      }
    }
  ]
}
