{
  "name": "simple-openai-preset",
  "version": "1.0.0",
  "description": "Simple OpenAI configuration preset",
  "author": "Your Name",
  "keywords": ["openai", "simple"],
  "schema": [
    {
      "id": "apiKey",
      "type": "password",
      "label": "OpenAI API Key",
      "prompt": "Please enter your OpenAI API Key",
      "placeholder": "sk-...",
      "required": true
    },
    {
      "id": "model",
      "type": "select",
      "label": "Select Model",
      "prompt": "Select the GPT model to use",
      "options": {
        "type": "static",
        "options": [
          {
            "label": "GPT-4o (Recommended)",
            "value": "gpt-4o"
          },
          {
            "label": "GPT-4o-mini (Fast)",
            "value": "gpt-4o-mini"
          },
          {
            "label": "GPT-3.5 Turbo (Economic)",
            "value": "gpt-3.5-turbo"
          }
        ]
      },
      "required": true,
      "defaultValue": "gpt-4o"
    },
    {
      "id": "useProxy",
      "type": "confirm",
      "label": "Use Proxy",
      "prompt": "Do you need to access OpenAI API via proxy?",
      "defaultValue": false
    },
    {
      "id": "proxyUrl",
      "type": "input",
      "label": "Proxy Address",
      "prompt": "Please enter the proxy address",
      "placeholder": "http://127.0.0.1:7890",
      "required": true,
      "when": {
        "field": "useProxy",
        "operator": "eq",
        "value": true
      }
    }
  ],
  "template": {
    "Providers": [
      {
        "name": "openai",
        "api_base_url": "https://api.openai.com/v1",
        "api_key": "{{apiKey}}",
        "models": ["{{model}}"]
      }
    ],
    "Router": {
      "default": "openai/{{model}}"
    },
    "PROXY_URL": "{{proxyUrl}}"
  },
  "configMappings": [
    {
      "target": "PROXY_URL",
      "value": "{{proxyUrl}}",
      "when": {
        "field": "useProxy",
        "operator": "eq",
        "value": true
      }
    }
  ]
}
